---
import loadBrixIcon from '../../utils/brix-icon-loader'
import LucideBookMarked from '~icons/lucide/book-marked'
import LucideCalendarRange from '~icons/lucide/calendar-range'
import LucideTicket from '~icons/lucide/ticket'
import LucidePalette from '~icons/lucide/palette'
import LucideInfo from '~icons/lucide/info'
import LucideScale from '~icons/lucide/scale'
import LucideHatGlasses from '~icons/lucide/hat-glasses'

type Props = {
  iconClass: string
  sidebarClass: string
  links: SidebarLink[]
  title: string
  description: string
}
const { links, iconClass, sidebarClass, title, description }: Props = Astro.props

export type SidebarLink = {
  // can't seem to import FunctionalComponent<> as type
  // eslint-disable-next-line @typescript-eslint/no-explicit-any
  icon: any
  label: string
  href: string
  hashes?: { hash: string; label: string }[]
}
export const dealersDenLinks: SidebarLink[] = [
  { icon: LucideBookMarked, label: 'Overview', href: '/dealers-den' },
  {
    icon: LucideCalendarRange,
    label: 'TIMELINE & SETUP',
    href: '/dealers-den/timeline',
    hashes: [
      { hash: 'hours', label: "Dealers' Den Hours" },
      { hash: 'before', label: "Before the Dealers' Den Opens" },
      { hash: 'setup', label: "Dealers' Den Setup" },
      { hash: 'open', label: "The Dealers' Den is Open!" },
      { hash: 'teardown', label: "Dealers' Den Teardown" }
    ]
  },
  {
    icon: LucideTicket,
    label: 'OBTAINING A DEALERSHIP',
    href: '/dealers-den/dealership',
    hashes: [
      { hash: 'application', label: 'Step I: Application' },
      { hash: 'approval', label: 'Step II: Approval' },
      { hash: 'payment', label: 'Step III: Payment' },
      { hash: 'placement', label: 'Step IV: Placement' },
      { hash: 'waitinglist', label: 'Waiting List' },
      { hash: 'cancellations', label: 'Cancellations' }
    ]
  },
  {
    icon: LucideBookMarked,
    label: 'RULES & GUIDELINES',
    href: '/dealers-den/rules',
    hashes: [
      { hash: 'merchandise', label: 'Guidelines on Merchandise' },
      { hash: 'sales', label: 'Guidelines on Sales' },
      { hash: 'activities', label: 'Guidelines on Activities' },
      { hash: 'copyrights', label: 'Copyrights Clause' },
      { hash: 'gambling', label: 'Games of Chance (Gambling)' }
    ]
  },
  {
    icon: LucidePalette,
    label: 'ARTIST ALLEY & ARTSHOW',
    href: '/dealers-den/alley-artshow',
    hashes: [
      { hash: 'artistalley', label: 'Artist Alley' },
      { hash: 'artshow', label: 'Art Show' }
    ]
  },
  {
    icon: LucideInfo,
    label: 'GLOSSARY & INFO',
    href: '/dealers-den/glossary',
    hashes: [
      { hash: 'glossary', label: 'Glossary' },
      { hash: 'administrativedetails', label: 'Administrative Details' }
    ]
  }
]
export const termsLinks: SidebarLink[] = [
  { icon: LucideBookMarked, label: 'TERMS & CONDITIONS', href: '/terms' },
  { icon: LucideScale, label: 'CODE OF CONDUCT', href: '/conduct' },
  { icon: LucideHatGlasses, label: 'PRIVACY POLICY', href: '/privacy' }
]

function getIconSvg(name: string) {
  return loadBrixIcon(name) ?? loadBrixIcon('question-mark')
}

function isActive(href: string) {
  const currentLastSection = Astro.url.pathname.split('/').filter(Boolean).at(-1) ?? ''
  const hrefPath = href.split(/[?#]/)[0] ?? ''
  const hrefLastSection = hrefPath.split('/').filter(Boolean).at(-1) ?? ''

  if (!currentLastSection && !hrefLastSection) {
    return true
  }

  return currentLastSection !== '' && currentLastSection === hrefLastSection
}

function hashIsActive(hash: string) {
  return Astro.url.hash.includes(hash)
}
---

<div class="sidebar-container">
  <aside class:list={['sidebar', sidebarClass]}>
    <div class="sidebar-top">
      <h4>{title}</h4>
      <p>{description}</p>
    </div>

    {
      !Astro.slots.has('header') && (
        <div class="sidebar-bottom sidebar-sticky fill-primary-500">
          {links.map(({ icon: Icon, label, href, hashes }) => (
            <div class="sidebar-item ">
              <a {href} class={`sidebar-trigger ${isActive(href) ? 'active' : iconClass}`}>
                <Icon />
                <span class="sidebar-link">{label}</span>
                {hashes && (
                  <>
                    <span
                      class="sidebar-icon sidebar-toggle-icon sidebar-toggle-icon-plus"
                      set:html={getIconSvg('plus')}
                    />
                    <span
                      class="sidebar-icon sidebar-toggle-icon sidebar-toggle-icon-minus"
                      set:html={getIconSvg('minus')}
                    />
                  </>
                )}
              </a>

              {hashes && (
                <div class="sidebar-hashes">
                  {hashes.map((hash) => (
                    <a href={href + '#' + hash.hash} class={`sidebar-hash ${hashIsActive(hash.hash) && 'active'}`}>
                      <span>{hash.label}</span>
                    </a>
                  ))}
                </div>
              )}
            </div>
          ))}
        </div>
      )
    }
  </aside>

  <main>
    {Astro.slots.has('header') && <slot name="header" />}
    {!Astro.slots.has('header') && <slot />}
  </main>
</div>

{
  Astro.slots.has('header') && (
    <div class="sidebar-container">
      <aside class="sidebar" class:list={['sidebar', sidebarClass]}>
        <div class="sidebar-bottom sidebar-sticky">
          {links.map(({ icon: Icon, label, href, hashes }) => (
            <div class="sidebar-item">
              <a href={href} class={`sidebar-trigger ${isActive(href) ? 'active' : iconClass}`}>
                <Icon />
                <span class="sidebar-link">{label}</span>
                {hashes && (
                  <>
                    <span
                      class="sidebar-icon sidebar-toggle-icon sidebar-toggle-icon-plus"
                      set:html={getIconSvg('plus')}
                    />
                    <span
                      class="sidebar-icon sidebar-toggle-icon sidebar-toggle-icon-minus"
                      set:html={getIconSvg('minus')}
                    />
                  </>
                )}
              </a>

              {hashes && (
                <div class="sidebar-hashes">
                  {hashes.map((hash) => (
                    <a href={href + '#' + hash.hash} class={`sidebar-hash ${hashIsActive(hash.hash) && 'active'}`}>
                      <span>{hash.label}</span>
                    </a>
                  ))}
                </div>
              )}
            </div>
          ))}
        </div>
      </aside>

      <main>
        <slot />
      </main>
    </div>
  )
}

<script>
  const accordions = document.querySelectorAll('.sidebar-bottom')

  const closeItem = (item: Element) => {
    const hashes = item.querySelector('.sidebar-hashes') as HTMLElement | null
    item.classList.remove('is-open')
    if (hashes) {
      hashes.style.maxHeight = '0px'
    }
  }

  const openItem = (item: Element) => {
    const hashes = item.querySelector('.sidebar-hashes') as HTMLElement | null
    item.classList.add('is-open')
    if (hashes) {
      hashes.style.maxHeight = `${hashes.scrollHeight}px`
    }
  }

  accordions.forEach((accordion) => {
    const items = Array.from(accordion.querySelectorAll('.sidebar-item'))

    items.forEach((item) => {
      const trigger = item.querySelector('.sidebar-trigger') as HTMLAnchorElement | null
      const hashes = item.querySelector('.sidebar-hashes') as HTMLElement | null

      if (!trigger || !hashes) {
        return
      }

      closeItem(item)

      trigger.addEventListener('click', (event) => {
        const target = event.target as Element | null
        const clickedToggleIcon = !!target?.closest('.sidebar-toggle-icon')

        if (!clickedToggleIcon && trigger.pathname !== window.location.pathname) {
          return
        }

        event.preventDefault()

        if (clickedToggleIcon) {
          event.stopPropagation()
        }

        const shouldOpen = !item.classList.contains('is-open')

        items.forEach((otherItem) => {
          if (otherItem !== item) {
            closeItem(otherItem)
          }
        })

        if (shouldOpen) {
          openItem(item)
          return
        }

        closeItem(item)
      })
    })

    const activeHash = accordion.querySelector('.sidebar-trigger.active')
    const activeItem = activeHash?.closest('.sidebar-item')
    if (activeItem) {
      openItem(activeItem)
    }
  })

  window.addEventListener('resize', () => {
    document.querySelectorAll('.sidebar-item.is-open .sidebar-hashes').forEach((hashes) => {
      const hashesElement = hashes as HTMLElement
      hashesElement.style.maxHeight = `${hashesElement.scrollHeight}px`
    })
  })
</script>

<style scoped lang="scss">
  @use '../styles/charter.scss';
  @use '../styles/text-styles.scss';

  .sidebar-container {
    display: flex;

    main {
      flex: 1;
      display: flex;
      justify-content: center;
    }
  }

  .sidebar {
    min-width: 360px;
    max-width: 360px;

    @media (max-width: 900px) {
      display: none;
    }
  }

  .sidebar-top {
    padding: 16px;
    margin-bottom: 32px;

    h4 {
      @include text-styles.heading4;
      margin-bottom: 16px;
    }
    p {
      @include text-styles.paragraphDefaultRegular;
    }
  }

  .sidebar-bottom {
    display: flex;
    flex-direction: column;

    &.sidebar-sticky {
      position: sticky;
      top: 0;
    }

    .sidebar-item {
      display: flex;
      flex-direction: column;

      .sidebar-toggle-icon-minus {
        display: none;
      }

      &.is-open {
        .sidebar-toggle-icon-plus {
          display: none;
        }

        .sidebar-toggle-icon-minus {
          display: inline-flex;
        }
      }
    }

    .sidebar-hashes {
      display: flex;
      flex-direction: column;
      max-height: 0;
      overflow: hidden;
      transition: max-height 0.2s ease;

      .sidebar-hash {
        @include text-styles.display3Regular;

        padding-left: 50px;
      }
    }

    a {
      @include text-styles.display3SemiBold;

      padding: 16px 16px;
      display: flex;
      align-items: center;
      gap: 12px;
      text-decoration: none;

      .sidebar-icon {
        display: inline-flex;
        font-size: 22px;
      }

      span {
        &.sidebar-link {
          flex: 1;
        }
      }

      &.active,
      &.active ~ .sidebar-hashes > .sidebar-hash {
        background-color: #fff;
      }
    }
  }
</style>
