---
import { getCollection } from 'astro:content'
import Base from '../../layouts/Base.astro'
import Sidebar, { termsLinks } from '../../layouts/Sidebar.astro'
import Socials from '../../content/socials.astro'
import MobileBottomNavbar from '../../components/MobileBottomNavbar.astro'

export async function getStaticPaths() {
  const faq_pages = await getCollection('faqPages')
  return faq_pages
    .filter((faq_page) => faq_page.data.slug.startsWith('faq/'))
    .map((faq_page) => ({ params: { slug: faq_page.data.slug.split('faq/')[1] }, props: { faq_page: faq_page } }))
}

const faq_page = Astro.props.faq_page.data
---

<Base>
  <Sidebar
    links={termsLinks}
    iconClass="text-secondary-500"
    sidebarClass="bg-secondary-50"
    title="Welcome to the legal nitty gritty"
    description=""
  >
    <section>
      <div class="content">
        <h1>Code of Conduct</h1>
        <p>Last updated: 30/03/2026</p>
        <p>
          {JSON.stringify(faq_page)}
        </p>
      </div>
      <MobileBottomNavbar
        backHref="/terms"
        backLabel="Terms and Conditions"
        nextHref="/privacy"
        nextLabel="Privacy Policy"
      />
    </section>
  </Sidebar>
  <Socials />
</Base>

<style scoped lang="scss">
  @use '../../styles/text-styles';
  @use '../../styles/charter';

  section {
    display: flex;
    flex-direction: column;
    align-items: center;
    max-width: 1200px;
    width: calc(100vw - 360px);
    margin: 0 auto;

    @media (max-width: 900px) {
      width: 100vw;
    }
  }

  .content {
    padding: 20px 60px;
    display: flex;
    flex-direction: column;
    width: 100%;
    color: charter.$primary-800;

    &:first-child {
      padding-top: 80px;
    }

    &:not(:has(~ .content)) {
      padding-bottom: 80px;
    }

    @media (max-width: 600px) {
      padding: 20px;

      &:first-child {
        padding-top: 40px;
      }

      &:not(:has(~ .content)) {
        padding-bottom: 40px;
      }
    }

    h1 {
      @include text-styles.heading1;
      margin-bottom: 16px;

      @media (max-width: 600px) {
        @include text-styles.heading3;
      }
    }

    h2 {
      @include text-styles.heading4;
      margin-bottom: 16px;
    }

    p:not(:last-child) {
      margin-bottom: 16px;
    }

    a {
      color: charter.$primary-500;
    }

    ul > li {
      list-style-type: disc;
    }
  }
</style>
